# ─────────────────────────────────────────────────────────────────────────
# Copy to `.env` for local dev, and set the same keys in the Vercel dashboard
# (Project → Settings → Environment Variables) for production.
# Anything prefixed VITE_ is PUBLIC (shipped to the browser). Everything else
# is server-only and used by the /api functions.
# ─────────────────────────────────────────────────────────────────────────

# --- Public (client) ---
# Your Cal.com booking link as `handle/event-slug` (e.g. hypernova/15min).
# Powers the inline scheduler embedded in the booking section.
VITE_CALCOM_LINK=

# Legacy Calendly link (no longer used by the site; kept for reference).
VITE_CALENDLY_URL=

# Set to "true" once STRIPE_SECRET_KEY is configured to show the Pay button.
VITE_STRIPE_ENABLED=false

# --- Cal.com management (server secret) ---
# Cal.com API v2 key for booking/event-type management via api.cal.com/v2.
CALCOM_API_KEY=

# --- Lead delivery (server) ---
# Resend API key from https://resend.com — enables real email delivery.
RESEND_API_KEY=
LEAD_TO_EMAIL=hello@hypernovaai.com
# Must be a verified sender in Resend (onboarding@resend.dev works for testing).
LEAD_FROM_EMAIL=HyperNova AI <onboarding@resend.dev>

# --- Payments (server) ---
# Stripe secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Optional: a pre-created Price ID; otherwise a $199 line item is built inline.
STRIPE_PRICE_ID=
# Optional: override the flat price (in cents).
ASSESSMENT_PRICE_CENTS=19900
# Optional: override post-checkout redirect targets.
CHECKOUT_SUCCESS_URL=
CHECKOUT_CANCEL_URL=
